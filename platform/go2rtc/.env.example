# go2rtc camera secrets
# Copy to /etc/homelab/secrets/go2rtc.env on geek and fill in real values.
# RTSP URLs include credentials — never commit actual values.
#
# To find your RTSP URLs:
#   Eufy Security app > Camera > Settings > Storage > NAS/RTSP > Enable RTSP
#   Note the URL shown (format: rtsp://HOMEBASE_IP:554/live/chN)
#
# The HomeBase IP and credentials are set in the Eufy app RTSP settings.

EUFY_RTSP_BACKYARD=rtsp://user:pass@192.168.1.X:554/live/ch0
EUFY_RTSP_BREEZEWAY=rtsp://user:pass@192.168.1.X:554/live/ch1
EUFY_RTSP_GARAGE=rtsp://user:pass@192.168.1.X:554/live/ch2
