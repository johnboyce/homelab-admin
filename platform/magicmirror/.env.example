# MagicMirror² secrets
# Copy to /etc/homelab/secrets/magicmirror.env on geek and fill in real values.
# Register a free account at https://openweathermap.org → API keys tab.
# Free tier: 60 calls/min, 1M calls/month — sufficient for 4 weather module instances.

OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
